{
  "extends": "@interviewos/tsconfig/base.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "noEmit": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
