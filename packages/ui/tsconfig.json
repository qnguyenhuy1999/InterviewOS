{
  "extends": "@interviewos/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/**/*",
    "components/**/*",
    "lib/**/*",
    "hooks/**/*",
    ".storybook/**/*",
    "vite.config.ts"
  ],
  "exclude": ["src/**/*.stories.tsx"]
}
