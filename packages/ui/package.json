{
  "name": "@interviewos/ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    "./styles/globals.css": "./src/globals.css",
    "./atoms/*": {
      "types": "./src/atoms/*/*.tsx",
      "development": "./src/atoms/*/*.tsx",
      "import": "./src/atoms/*/*.tsx",
      "default": "./src/atoms/*/*.tsx"
    },
    "./molecules/*": {
      "types": "./src/molecules/*/*.tsx",
      "development": "./src/molecules/*/*.tsx",
      "import": "./src/molecules/*/*.tsx",
      "default": "./src/molecules/*/*.tsx"
    },
    "./organisms/*": {
      "types": "./src/organisms/*/*.tsx",
      "development": "./src/organisms/*/*.tsx",
      "import": "./src/organisms/*/*.tsx",
      "default": "./src/organisms/*/*.tsx"
    },
    "./layouts/*": {
      "types": "./src/layouts/*/*.tsx",
      "development": "./src/layouts/*/*.tsx",
      "import": "./src/layouts/*/*.tsx",
      "default": "./src/layouts/*/*.tsx"
    },
    "./pages/*": {
      "types": "./src/pages/*/index.ts",
      "development": "./src/pages/*/index.ts",
      "import": "./src/pages/*/index.ts",
      "default": "./src/pages/*/index.ts"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "development": "./src/lib/utils.ts",
      "import": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .storybook src vite.config.ts",
    "format": "prettier --write .storybook src vite.config.ts",
    "storybook": "storybook dev -p 6006",
    "build": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/roboto": "^5.2.10",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@interviewos/eslint-config": "workspace:*",
    "@interviewos/tsconfig": "workspace:*",
    "@interviewos/types": "workspace:*",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
