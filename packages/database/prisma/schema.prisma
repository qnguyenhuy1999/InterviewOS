generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
}

enum EnglishLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  NATIVE
}

enum NoteStatus {
  DRAFT
  REVIEWING
  NEEDS_PRACTICE
  INTERVIEW_READY
  MASTERED
  PUBLISHED
  ARCHIVED
}

enum NoteType {
  CONCEPT
  ALGORITHM
  SYSTEM_DESIGN
  BEHAVIORAL
  LANGUAGE_SPECIFIC
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
  MIXED
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum RecommendationStatus {
  PENDING
  DISMISSED
  COMPLETED
}

enum EnglishNoteStatus {
  NEEDS_PRACTICE
  REVIEWING
  IMPROVED
  MASTERED
}

enum WeakConceptStatus {
  ACTIVE
  IMPROVING
  RESOLVED
  IGNORED
}

enum ReviewItemType {
  TECHNICAL_NOTE
  GENERATED_QUESTION
  ENGLISH_NOTE
  WEAK_CONCEPT
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum LearningPathItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SNOOZED
  SKIPPED
}

enum AIValidationStatus {
  SUCCESS
  VALIDATION_FAILED
  PROVIDER_ERROR
}

enum TurnRole {
  INTERVIEWER
  CANDIDATE
}

enum TurnDecision {
  FOLLOW_UP
  DEEP_DIVE
  CLARIFY
  CHALLENGE
  ESCALATE
  ADVANCE
  WRAP_UP
  EVALUATE
}

enum SessionMode {
  STANDARD
  MULTI_TURN
  COMPANY
}

enum EvaluationStatus {
  PENDING
  COMPLETE
  FAILED
}

enum StarDimension {
  SITUATION
  TASK
  ACTION
  RESULT
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  passwordHash      String?
  emailVerifiedAt   DateTime?
  name              String?
  avatarUrl         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  profile           UserLearningProfile?
  authSessions      AuthSession[]
  passwordResets    PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  notes             TechnicalNote[]
  sessions          InterviewSession[]
  englishNotes      EnglishNote[]
  weakConcepts      UserWeakConcept[]
  englishWeaknesses UserEnglishWeakness[]
  recommendations   LearningRecommendation[]
  resumes           ResumeAnalysis[]
  aiRequestLogs     AIRequestLog[]
  reviewItems         ReviewItem[]
  reviewAttempts      ReviewAttempt[]
  learningPathItems   LearningPathItem[]
  readinessSnapshots  ReadinessSnapshot[]

  @@index([createdAt])
}

model UserLearningProfile {
  id                   String          @id @default(cuid())
  userId               String          @unique
  targetRole           String
  currentLevel         ExperienceLevel
  targetLevel          ExperienceLevel
  englishLevel         EnglishLevel
  techStack            String[]
  interviewGoals       String[]
  preferredOutputStyle String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AuthSession {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  lastSeenAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, usedAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, usedAt])
  @@index([expiresAt])
}

model TechnicalNote {
  id            String          @id @default(cuid())
  userId        String
  title         String
  rawInput      String
  status        NoteStatus      @default(DRAFT)
  type          NoteType        @default(CONCEPT)
  overrideRole  String?
  overrideLevel ExperienceLevel?
  overrideStack String[] @default([])
  overrideGoals String[] @default([])
  overrideEnglishLevel EnglishLevel?
  preferredOutputStyle String?
  structuredContent Json?
  aiMetadata    Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections      TechnicalNoteSection[]
  questions     NoteGeneratedQuestion[]
  sessions      InterviewSession[]
  reviewItems   ReviewItem[]

  @@index([userId, status, type, createdAt])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model TechnicalNoteSection {
  id        String        @id @default(cuid())
  noteId    String
  order     Int
  heading   String
  content   String
  aiMetadata Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  note      TechnicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([createdAt])
}

model NoteGeneratedQuestion {
  id         String             @id @default(cuid())
  noteId     String
  question   String
  category   String
  expectedAnswer String?
  expectedConcepts String[]
  difficulty QuestionDifficulty
  sourceSection String
  aiMetadata Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  note       TechnicalNote      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  reviewItems ReviewItem[]

  @@index([noteId])
  @@index([createdAt])
}

model InterviewSession {
  id         String          @id @default(cuid())
  userId     String
  type       InterviewType
  status     NoteStatus
  noteId     String?
  sourceQuestionId String?
  overrideRole String?
  overrideLevel ExperienceLevel?
  overrideStack String[] @default([])
  overrideGoals String[] @default([])
  overrideEnglishLevel EnglishLevel?
  preferredOutputStyle String?
  mode           SessionMode       @default(STANDARD)
  companyModeId  String?
  maxTurns       Int               @default(10)
  currentTurnNum Int               @default(0)
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  note           TechnicalNote?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  companyMode    CompanyMode?      @relation(fields: [companyModeId], references: [id])
  questions      InterviewQuestion[]
  turns          InterviewTurn[]
  evaluation     InterviewEvaluation?

  @@index([userId, status, type, createdAt])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model InterviewQuestion {
  id         String            @id @default(cuid())
  sessionId  String
  order      Int
  question   String
  category   String
  difficulty QuestionDifficulty
  expectedConcepts String[]
  sourceSection String
  topicTags  String[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  session    InterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer     InterviewAnswer?

  @@index([sessionId])
  @@index([createdAt])
}

model InterviewAnswer {
  id             String            @id @default(cuid())
  questionId     String            @unique
  rawAnswer      String
  technicalScore Int?
  englishScore   Int?
  clarityScore   Int?
  overallScore   Int?
  aiFeedback     String?
  technicalFeedback Json?
  englishFeedback Json?
  nextRecommendedQuestion Json?
  recommendedLearning Json?
  weakConcepts String[]
  aiMetadata     Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  question       InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  englishNotes   EnglishNote[]

  @@index([questionId])
  @@index([createdAt])
}

model EnglishNote {
  id                     String            @id @default(cuid())
  userId                 String
  answerId               String
  originalSentence       String
  correctedSentence      String
  naturalVersion         String
  explanation            String
  grammarTopic           String
  recommendedStudyTopics String[]
  practicePatterns       String[]
  status                 EnglishNoteStatus @default(NEEDS_PRACTICE)
  aiMetadata             Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer                 InterviewAnswer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  reviewItems            ReviewItem[]

  @@index([userId, answerId])
  @@index([userId])
  @@index([createdAt])
}

model UserWeakConcept {
  id              String   @id @default(cuid())
  userId          String
  concept         String
  occurrenceCount Int      @default(1)
  status          WeakConceptStatus @default(ACTIVE)
  lastSeenAt      DateTime
  sourceAnswerIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewItems     ReviewItem[]

  @@index([userId])
  @@index([createdAt])
}

model UserEnglishWeakness {
  id              String   @id @default(cuid())
  userId          String
  topic           String
  occurrenceCount Int      @default(1)
  lastSeenAt      DateTime
  sourceAnswerIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model LearningRecommendation {
  id         String               @id @default(cuid())
  userId     String
  status     RecommendationStatus @default(PENDING)
  type       String
  payload    Json
  aiMetadata Json?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model ResumeAnalysis {
  id             String    @id @default(cuid())
  userId         String
  fileUrl        String?
  rawText        String?
  analysisResult Json?
  aiMetadata     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AIRequestLog {
  id               String             @id @default(cuid())
  userId           String?
  operation        String
  provider         String
  model            String
  promptKey        String
  promptVersion    String
  schemaKey        String
  schemaVersion    String
  inputHash        String
  validationStatus AIValidationStatus
  tokenUsage       Json?
  latencyMs        Int
  generatedAt      DateTime
  errorMessage     String?
  createdAt        DateTime           @default(now())
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([operation, createdAt])
  @@index([validationStatus, createdAt])
}

model ReviewItem {
  id                  String              @id @default(cuid())
  userId              String
  type                ReviewItemType
  sourceId            String
  sourceLabel         String
  weaknessScore       Int                 @default(0)
  masteryScore        Float               @default(0)
  nextReviewAt        DateTime
  reviewIntervalDays  Int                 @default(1)
  lastReviewedAt      DateTime?
  lastFailureAt       DateTime?
  lastRating          ReviewRating?
  metadata            Json?
  aiMetadata          Json?
  technicalNoteId     String?
  generatedQuestionId String?
  englishNoteId       String?
  weakConceptId       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  technicalNote       TechnicalNote?      @relation(fields: [technicalNoteId], references: [id], onDelete: Cascade)
  generatedQuestion   NoteGeneratedQuestion? @relation(fields: [generatedQuestionId], references: [id], onDelete: Cascade)
  englishNote         EnglishNote?        @relation(fields: [englishNoteId], references: [id], onDelete: Cascade)
  weakConcept         UserWeakConcept?    @relation(fields: [weakConceptId], references: [id], onDelete: Cascade)
  attempts            ReviewAttempt[]
  learningPathItems   LearningPathItem[]

  @@unique([userId, type, sourceId])
  @@index([userId, nextReviewAt])
  @@index([userId, weaknessScore])
  @@index([userId, lastFailureAt])
}

model ReviewAttempt {
  id                 String       @id @default(cuid())
  reviewItemId       String
  userId             String
  rating             ReviewRating
  masteryBefore      Float
  masteryAfter       Float
  reviewIntervalDays Int
  nextReviewAt       DateTime
  createdAt          DateTime     @default(now())
  reviewItem         ReviewItem   @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewItemId, createdAt])
}

model LearningPathItem {
  id                 String                 @id @default(cuid())
  userId             String
  type               String
  title              String
  reason             String
  actionPath         String
  status             LearningPathItemStatus @default(PENDING)
  priorityScore      Float
  availableAt        DateTime               @default(now())
  snoozedUntil       DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  skippedAt          DateTime?
  sourceReviewItemId String?
  metadata           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceReviewItem   ReviewItem?            @relation(fields: [sourceReviewItemId], references: [id], onDelete: SetNull)

  @@index([userId, status, availableAt])
  @@index([userId, priorityScore])
}

model CompanyMode {
  id        String             @id @default(cuid())
  slug      String             @unique
  name      String
  config    Json
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sessions  InterviewSession[]

  @@index([slug])
  @@index([isActive])
}

model InterviewTurn {
  id          String        @id @default(cuid())
  sessionId   String
  turnNumber  Int
  role        TurnRole
  content     String
  decision    TurnDecision?
  topicTags   String[]
  aiMetadata  Json?
  createdAt   DateTime      @default(now())
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, turnNumber])
  @@index([sessionId, role])
}

model InterviewEvaluation {
  id              String           @id @default(cuid())
  sessionId       String           @unique
  status          EvaluationStatus @default(PENDING)
  overallScore    Int?
  dimensionScores Json
  starScores      Json?
  designScores    Json?
  strengths       String[]
  improvements    String[]
  coachingNotes   String[]
  weakConcepts    String[]
  aiMetadata      Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  session         InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
}

model ReadinessSnapshot {
  id                      String   @id @default(cuid())
  userId                  String
  overallScore            Int
  confidenceLevel         Float
  technicalMastery        Float
  interviewPerformance    Float
  behavioralPerformance   Float
  systemDesignPerformance Float
  englishCommunication    Float
  reviewCompletion        Float
  learningProgress        Float
  breakdown               Json
  improvementTrend        Float    @default(0)
  computedAt              DateTime @default(now())
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, computedAt])
}
