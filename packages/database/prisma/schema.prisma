generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
}

enum EnglishLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  NATIVE
}

enum NoteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NoteType {
  CONCEPT
  ALGORITHM
  SYSTEM_DESIGN
  BEHAVIORAL
  LANGUAGE_SPECIFIC
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
  MIXED
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum RecommendationStatus {
  PENDING
  DISMISSED
  COMPLETED
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  name              String?
  avatarUrl         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  profile           UserLearningProfile?
  notes             TechnicalNote[]
  sessions          InterviewSession[]
  englishNotes      EnglishNote[]
  weakConcepts      UserWeakConcept[]
  englishWeaknesses UserEnglishWeakness[]
  recommendations   LearningRecommendation[]
  resumes           ResumeAnalysis[]

  @@index([createdAt])
}

model UserLearningProfile {
  id                   String          @id @default(cuid())
  userId               String          @unique
  targetRole           String
  currentLevel         ExperienceLevel
  targetLevel          ExperienceLevel
  englishLevel         EnglishLevel
  techStack            String[]
  interviewGoals       String[]
  preferredOutputStyle String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model TechnicalNote {
  id            String          @id @default(cuid())
  userId        String
  title         String
  rawInput      String
  status        NoteStatus      @default(DRAFT)
  type          NoteType        @default(CONCEPT)
  overrideRole  String?
  overrideLevel ExperienceLevel?
  overrideStack String[]
  overrideGoals String[]
  overrideEnglishLevel EnglishLevel?
  preferredOutputStyle String?
  structuredContent Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections      TechnicalNoteSection[]
  questions     NoteGeneratedQuestion[]
  sessions      InterviewSession[]

  @@index([userId, status, type, createdAt])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model TechnicalNoteSection {
  id        String        @id @default(cuid())
  noteId    String
  order     Int
  heading   String
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  note      TechnicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([createdAt])
}

model NoteGeneratedQuestion {
  id         String             @id @default(cuid())
  noteId     String
  question   String
  category   String
  expectedAnswer String?
  expectedConcepts String[]
  difficulty QuestionDifficulty
  sourceSection String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  note       TechnicalNote      @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([createdAt])
}

model InterviewSession {
  id         String          @id @default(cuid())
  userId     String
  type       InterviewType
  status     NoteStatus
  noteId     String?
  sourceQuestionId String?
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       TechnicalNote?  @relation(fields: [noteId], references: [id], onDelete: SetNull)
  questions  InterviewQuestion[]

  @@index([userId, status, type, createdAt])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model InterviewQuestion {
  id         String            @id @default(cuid())
  sessionId  String
  order      Int
  question   String
  category   String
  difficulty QuestionDifficulty
  expectedConcepts String[]
  sourceSection String
  topicTags  String[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  session    InterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer     InterviewAnswer?

  @@index([sessionId])
  @@index([createdAt])
}

model InterviewAnswer {
  id             String            @id @default(cuid())
  questionId     String            @unique
  rawAnswer      String
  technicalScore Int?
  englishScore   Int?
  clarityScore   Int?
  overallScore   Int?
  aiFeedback     String?
  technicalFeedback Json?
  englishFeedback Json?
  nextRecommendedQuestion Json?
  recommendedLearning Json?
  weakConcepts String[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  question       InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  englishNotes   EnglishNote[]

  @@index([questionId])
  @@index([createdAt])
}

model EnglishNote {
  id                     String            @id @default(cuid())
  userId                 String
  answerId               String
  originalSentence       String
  correctedSentence      String
  naturalVersion         String
  explanation            String
  grammarTopic           String
  recommendedStudyTopics String[]
  practicePatterns       String[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer                 InterviewAnswer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([userId, answerId])
  @@index([userId])
  @@index([createdAt])
}

model UserWeakConcept {
  id              String   @id @default(cuid())
  userId          String
  concept         String
  occurrenceCount Int      @default(1)
  lastSeenAt      DateTime
  sourceAnswerIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model UserEnglishWeakness {
  id              String   @id @default(cuid())
  userId          String
  topic           String
  occurrenceCount Int      @default(1)
  lastSeenAt      DateTime
  sourceAnswerIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model LearningRecommendation {
  id         String               @id @default(cuid())
  userId     String
  status     RecommendationStatus @default(PENDING)
  type       String
  payload    Json
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model ResumeAnalysis {
  id             String    @id @default(cuid())
  userId         String
  fileUrl        String?
  rawText        String?
  analysisResult Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
