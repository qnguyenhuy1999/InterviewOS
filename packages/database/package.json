{
  "name": "@interviewos/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('node:fs'); const path='dist/generated/prisma/client.js'; const source=fs.readFileSync(path,'utf8'); fs.writeFileSync(path, source.replace(\\\"globalThis['__dirname'] = path.dirname((0, node_url_1.fileURLToPath)(import.meta.url));\\\", \\\"globalThis['__dirname'] = __dirname;\\\"));\"",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:validate": "dotenv -e ../../.env -- prisma validate",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@interviewos/types": "workspace:*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@interviewos/tsconfig": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
