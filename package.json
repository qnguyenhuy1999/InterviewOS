{
  "name": "interviewos-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "tsx --test apps/api/src/**/*.test.ts packages/ai/src/**/*.test.ts",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@interviewos/eslint-config": "workspace:*",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.20.6",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw"
    ]
  }
}
