# PostgreSQL connection string used by Prisma and the API.
DATABASE_URL=postgresql://postgres:1234@localhost:5432/interviewos

# Redis connection string for future queues, caching, or session infrastructure.
REDIS_URL=redis://localhost:6379

# JWT signing secret used by the API auth module.
JWT_SECRET=change-me-in-production

# Session cookie name.
AUTH_COOKIE_NAME=interviewos_session

# Session TTL in days (1-30).
AUTH_SESSION_TTL_DAYS=7

# Password reset token TTL in minutes (5-1440).
PASSWORD_RESET_TTL_MINUTES=30

# Email verification token TTL in hours (1-168).
EMAIL_VERIFICATION_TTL_HOURS=24

# Web app base URL (used for email links, CORS, etc.).
WEB_APP_URL=http://localhost:3000

# Email provider: "console" (logs to stdout) or "noop" (discards).
EMAIL_PROVIDER=console

# OpenAI API key for real AI provider usage.
OPENAI_API_KEY=sk-...

# Optional: custom OpenAI-compatible gateway base URL.
# OPENAI_GATEWAY_BASE_URL=https://your-gateway.example.com

# OpenAI model name.
OPENAI_MODEL=gpt-5.4-mini

# Optional: OpenAI organization ID.
# OPENAI_ORGANIZATION=org-...

# Optional: OpenAI project ID.
# OPENAI_PROJECT=proj-...

# AI provider selector. Use "mock" during local development.
AI_PROVIDER=mock

# Operator-only AI observability endpoints. Leave disabled unless explicitly needed.
AI_OBSERVABILITY_ENABLED=false

# Public API base URL consumed by the Next.js web app.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Node runtime environment.
NODE_ENV=development
